# Copy this to .env and fill in your values
DB_PASSWORD=choose_a_strong_password
JWT_SECRET=choose_a_long_random_string_at_least_32_chars
FRONTEND_URL=http://your-server-ip-or-domain
API_URL=http://your-server-ip-or-domain/api

# SMTP — email confirmation
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
# Leave SMTP_USER and SMTP_PASS blank if your local mail server doesn't require auth
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HelpDesk" <helpdesk@your-domain>
