# Copy this to .env and fill in your values
DB_PASSWORD=choose_a_strong_password
JWT_SECRET=choose_a_long_random_string_at_least_32_chars
FRONTEND_URL=http://your-server-ip-or-domain
API_URL=http://your-server-ip-or-domain/api

# SMTP — outgoing email (confirmation + ticket notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Leave SMTP_USER / SMTP_PASS blank if your relay does not require auth.
# For Gmail, SMTP_PASS must be a Google App Password (not your account password).
SMTP_USER=
SMTP_PASS=
# Display name + envelope-from used for outgoing messages
SMTP_NAME=HelpDesk
SMTP_EMAIL=helpdesk@your-domain
